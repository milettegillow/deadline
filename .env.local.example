# Deadline — environment variables (NONE are required for the current frontend-only build).
# Copy this file to `.env.local` once the backend is wired up. Do not commit `.env.local`.

# --- Supabase (Postgres database + magic-link auth) ---
# Public project URL, safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Public anon key, safe to expose to the browser (row-level security enforces access).
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# Service role key — SERVER ONLY, full database access. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# --- Resend (sending and receiving the nag emails) ---
RESEND_API_KEY=re_your_resend_api_key

# --- Anthropic / Claude (Haiku reads email replies to detect "done") ---
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
